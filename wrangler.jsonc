{
  "$schema": "https://json.schemastore.org/wrangler.json",
  "name": "finanalyzer-api-demo",
  "main": "src/index.ts",
  "compatibility_date": "2024-06-20",
  "compatibility_flags": ["nodejs_compat"],
  "kv_namespaces": [
    {
      "binding": "STORE",
      "id": "demo-store",
      "preview_id": "demo-store-preview"
    }
  ]
}
