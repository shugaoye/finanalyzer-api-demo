{
  "name": "finanalyzer-api-demo",
  "version": "1.5.12",
  "private": true,
  "description": "Finanalyzer API demo for Cloudflare Workers",
  "scripts": {
    "dev": "wrangler dev --port 8787",
    "start": "wrangler dev --port 8787",
    "cf:deploy": "wrangler deploy",
    "deploy": "wrangler deploy",
    "build": "wrangler deploy --dry-run --outdir dist",
    "check": "wrangler types && tsc --noEmit",
    "generate:openapi": "node scripts/generate-openapi-ts.js"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240620.0",
    "@types/node": "^20.12.7",
    "typescript": "^5.4.5",
    "wrangler": "^3.63.0"
  }
}
